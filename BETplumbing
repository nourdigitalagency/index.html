<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>B.E.T. Plumbing LLC — Pittsburgh, PA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,300;0,400;1,300;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --concrete: #1a1a1a;
  --charcoal: #111111;
  --steel: #2a2a2a;
  --pipe: #e06b1a;
  --pipe-light: #f5a55a;
  --pipe-pale: #fde8d3;
  --off-white: #f0ece4;
  --muted: #888;
  --border: rgba(255,255,255,0.08);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
background: var(–charcoal);
color: var(–off-white);
font-family: ‘Source Serif 4’, Georgia, serif;
font-weight: 300;
overflow-x: hidden;
}

/* ── NAV ── */
nav {
position: fixed; top: 0; left: 0; right: 0; z-index: 200;
display: flex; align-items: center; justify-content: space-between;
padding: 1.1rem 3.5rem;
background: rgba(17,17,17,0.92);
backdrop-filter: blur(12px);
border-bottom: 1px solid rgba(224,107,26,0.2);
animation: slideDown 0.6s ease both;
}
.logo {
font-family: ‘Oswald’, sans-serif;
font-size: 1.35rem; font-weight: 700;
letter-spacing: 0.12em; color: var(–off-white);
text-decoration: none;
}
.logo span { color: var(–pipe); }
.nav-right { display: flex; align-items: center; gap: 2rem; }
.nav-right a {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
color: var(–muted); text-decoration: none; transition: color 0.2s;
}
.nav-right a:hover { color: var(–off-white); }
.nav-call {
font-family: ‘Oswald’, sans-serif !important;
font-size: 0.95rem !important; letter-spacing: 0.08em !important;
color: var(–pipe) !important; border: 1px solid var(–pipe);
padding: 0.5rem 1.2rem; transition: all 0.25s !important;
}
.nav-call:hover { background: var(–pipe) !important; color: #fff !important; }

/* ── HERO ── */
.hero {
height: 100vh; min-height: 600px;
position: relative; display: flex; align-items: flex-end;
overflow: hidden;
}
.hero-bg {
position: absolute; inset: 0;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover; background-position: center 40%;
filter: brightness(0.35);
transform: scale(1.05);
animation: slowZoom 12s ease-out both;
}
.hero-overlay {
position: absolute; inset: 0;
background: linear-gradient(
to top,
rgba(17,17,17,1) 0%,
rgba(17,17,17,0.5) 40%,
rgba(17,17,17,0.1) 100%
);
}
.hero-content {
position: relative; z-index: 2;
padding: 0 4rem 5rem;
max-width: 820px;
animation: fadeUp 1s 0.4s ease both; opacity: 0;
}
.hero-tag {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
color: var(–pipe); margin-bottom: 1.2rem;
display: flex; align-items: center; gap: 0.75rem;
}
.hero-tag::before {
content: ‘’; display: block;
width: 32px; height: 1px; background: var(–pipe);
}
.hero h1 {
font-family: ‘Oswald’, sans-serif;
font-size: clamp(3.5rem, 7vw, 6.5rem);
font-weight: 700; line-height: 0.95;
letter-spacing: -0.01em;
color: var(–off-white);
margin-bottom: 1.5rem;
text-transform: uppercase;
}
.hero h1 em {
color: var(–pipe); font-style: normal;
display: block;
}
.hero-desc {
font-size: 1.1rem; line-height: 1.75;
color: rgba(240,236,228,0.7);
max-width: 520px; margin-bottom: 2.5rem;
}
.hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
.btn-main {
font-family: ‘Oswald’, sans-serif;
font-size: 1rem; font-weight: 600; letter-spacing: 0.1em;
text-transform: uppercase; text-decoration: none;
background: var(–pipe); color: #fff;
padding: 1rem 2.4rem; display: inline-block;
transition: all 0.25s; border: 2px solid var(–pipe);
}
.btn-main:hover { background: transparent; color: var(–pipe); }
.btn-outline {
font-family: ‘Oswald’, sans-serif;
font-size: 1rem; font-weight: 500; letter-spacing: 0.1em;
text-transform: uppercase; text-decoration: none;
color: var(–off-white); border: 1px solid rgba(240,236,228,0.3);
padding: 1rem 2rem; display: inline-block;
transition: all 0.25s;
}
.btn-outline:hover { border-color: var(–off-white); }

.hero-stats {
position: absolute; right: 4rem; bottom: 5rem; z-index: 2;
display: flex; flex-direction: column; gap: 1.5rem; text-align: right;
animation: fadeUp 1s 0.7s ease both; opacity: 0;
}
.stat { display: flex; flex-direction: column; gap: 0.15rem; }
.stat-n {
font-family: ‘Oswald’, sans-serif;
font-size: 2.2rem; font-weight: 700; color: var(–pipe); line-height: 1;
}
.stat-l {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
color: var(–muted);
}

/* ── TICKER ── */
.ticker {
background: var(–pipe);
padding: 0.7rem 0; overflow: hidden;
}
.ticker-inner {
display: flex; gap: 0;
animation: ticker 22s linear infinite;
width: max-content;
}
.ticker-item {
font-family: ‘Oswald’, sans-serif;
font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em;
text-transform: uppercase; color: #fff;
padding: 0 2.5rem; white-space: nowrap;
}
.ticker-item::after {
content: ‘◆’; margin-left: 2.5rem; opacity: 0.5;
}

/* ── WORK GALLERY ── */
.gallery-section {
padding: 6rem 0 0;
}
.section-header {
padding: 0 4rem 3.5rem;
display: flex; align-items: flex-end; justify-content: space-between;
}
.section-tag {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
color: var(–pipe); margin-bottom: 0.75rem;
}
.section-title {
font-family: ‘Oswald’, sans-serif;
font-size: clamp(2rem, 4vw, 3.2rem);
font-weight: 700; text-transform: uppercase;
letter-spacing: 0.02em; color: var(–off-white);
line-height: 1.05;
}
.section-title em { color: var(–pipe); font-style: normal; }

/* Masonry-style gallery */
.gallery-grid {
display: grid;
grid-template-columns: repeat(12, 1fr);
grid-template-rows: 280px 280px;
gap: 3px;
}
.gimg {
overflow: hidden; position: relative; cursor: pointer;
background: var(–steel);
}
.gimg img {
width: 100%; height: 100%;
object-fit: cover;
transition: transform 0.6s ease, filter 0.4s;
filter: brightness(0.88) saturate(0.9);
}
.gimg:hover img { transform: scale(1.06); filter: brightness(1) saturate(1); }
.gimg-label {
position: absolute; bottom: 0; left: 0; right: 0;
background: linear-gradient(transparent, rgba(0,0,0,0.75));
padding: 1.5rem 1.2rem 0.9rem;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase;
color: rgba(255,255,255,0.7);
opacity: 0; transition: opacity 0.3s;
}
.gimg:hover .gimg-label { opacity: 1; }

/* Grid placement */
.g1 { grid-column: 1 / 5; grid-row: 1; }
.g2 { grid-column: 5 / 9; grid-row: 1; }
.g3 { grid-column: 9 / 13; grid-row: 1 / 3; }
.g4 { grid-column: 1 / 4; grid-row: 2; }
.g5 { grid-column: 4 / 7; grid-row: 2; }
.g6 { grid-column: 7 / 9; grid-row: 2; }

/* ── VIDEO ── */
.video-section {
padding: 5rem 4rem;
display: grid; grid-template-columns: 1fr 1fr;
gap: 5rem; align-items: center;
}
.video-wrap {
position: relative; background: var(–steel);
overflow: hidden; aspect-ratio: 16/10;
border: 1px solid rgba(255,255,255,0.06);
}
.video-wrap video {
width: 100%; height: 100%; object-fit: cover; display: block;
}
.video-placeholder {
width: 100%; height: 100%;
display: flex; flex-direction: column;
align-items: center; justify-content: center;
background: var(–steel); gap: 1rem;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.75rem; letter-spacing: 0.1em;
color: var(–muted); text-transform: uppercase;
}
.play-btn {
width: 64px; height: 64px; border-radius: 50%;
border: 2px solid var(–pipe);
display: flex; align-items: center; justify-content: center;
font-size: 1.4rem; color: var(–pipe);
}
.video-text .section-tag { margin-bottom: 0.5rem; }
.video-text .section-title { margin-bottom: 1.2rem; font-size: 2.2rem; }
.video-text p {
font-size: 1rem; line-height: 1.8;
color: rgba(240,236,228,0.65); margin-bottom: 1.5rem;
}
.video-text p + p { margin-top: -0.5rem; }

/* ── SERVICES ── */
.services-section { padding: 6rem 4rem; background: rgba(255,255,255,0.015); }
.services-grid {
display: grid; grid-template-columns: repeat(3, 1fr);
border: 1px solid var(–border);
margin-top: 3.5rem;
}
.svc {
padding: 2.2rem 2rem;
border-right: 1px solid var(–border);
border-bottom: 1px solid var(–border);
transition: background 0.3s; position: relative;
overflow: hidden;
}
.svc:nth-child(3n) { border-right: none; }
.svc:nth-last-child(-n+3) { border-bottom: none; }
.svc::before {
content: ‘’; position: absolute;
left: 0; top: 0; bottom: 0; width: 3px;
background: var(–pipe); transform: scaleY(0);
transform-origin: bottom; transition: transform 0.35s;
}
.svc:hover { background: rgba(224,107,26,0.04); }
.svc:hover::before { transform: scaleY(1); }
.svc-num {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; color: var(–pipe);
letter-spacing: 0.15em; margin-bottom: 1rem;
}
.svc-name {
font-family: ‘Oswald’, sans-serif;
font-size: 1.1rem; font-weight: 600; letter-spacing: 0.05em;
text-transform: uppercase; color: var(–off-white); margin-bottom: 0.6rem;
}
.svc-desc { font-size: 0.875rem; color: var(–muted); line-height: 1.7; }

/* ── WHY ── */
.why-section {
padding: 6rem 4rem;
display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
}
.why-img {
position: relative; overflow: hidden;
aspect-ratio: 4/5;
border: 1px solid var(–border);
}
.why-img img { width: 100%; height: 100%; object-fit: cover; display: block; filter: brightness(0.85) saturate(0.85); }
.why-img-badge {
position: absolute; bottom: 1.5rem; left: 1.5rem;
background: var(–pipe); padding: 0.75rem 1.2rem;
}
.why-img-badge span {
font-family: ‘Oswald’, sans-serif;
font-size: 0.85rem; font-weight: 600; letter-spacing: 0.1em;
text-transform: uppercase; color: #fff;
}
.why-right { padding-top: 1rem; }
.why-right .section-title { margin-bottom: 1.5rem; }
.why-right > p {
font-size: 1rem; line-height: 1.85;
color: rgba(240,236,228,0.65); margin-bottom: 2rem;
}
.pillars { display: flex; flex-direction: column; gap: 1.2rem; margin-top: 2rem; }
.pill {
display: grid; grid-template-columns: 48px 1fr;
gap: 1.2rem; align-items: start;
padding: 1.2rem; border: 1px solid var(–border);
transition: border-color 0.3s;
}
.pill:hover { border-color: rgba(224,107,26,0.4); }
.pill-num {
font-family: ‘Oswald’, sans-serif;
font-size: 1.5rem; font-weight: 700; color: var(–pipe);
line-height: 1;
}
.pill-title {
font-family: ‘Oswald’, sans-serif;
font-size: 0.95rem; font-weight: 600; letter-spacing: 0.06em;
text-transform: uppercase; color: var(–off-white); margin-bottom: 0.3rem;
}
.pill-body { font-size: 0.82rem; color: var(–muted); line-height: 1.65; }

/* ── REVIEWS ── */
.reviews-section { padding: 6rem 4rem; background: rgba(255,255,255,0.015); }
.reviews-scroll {
display: flex; gap: 1.5rem; overflow-x: auto;
margin-top: 3rem; padding-bottom: 1rem;
scrollbar-width: thin; scrollbar-color: var(–pipe) var(–steel);
}
.rev {
flex: 0 0 320px;
border: 1px solid var(–border); padding: 1.8rem;
transition: border-color 0.3s;
}
.rev:hover { border-color: rgba(224,107,26,0.35); }
.rev-stars { color: var(–pipe); font-size: 0.85rem; letter-spacing: 3px; margin-bottom: 1rem; }
.rev-text {
font-size: 0.875rem; line-height: 1.8;
color: rgba(240,236,228,0.7); font-style: italic; margin-bottom: 1rem;
}
.rev-author { font-family: ‘IBM Plex Mono’, monospace; font-size: 0.72rem; color: var(–pipe); letter-spacing: 0.1em; }
.rev-date { font-size: 0.68rem; color: var(–muted); margin-top: 0.2rem; }

/* ── CTA BAND ── */
.cta-band {
display: grid; grid-template-columns: 1fr auto;
gap: 3rem; align-items: center;
margin: 0 4rem 6rem;
padding: 4rem;
background-image: url(‘data:image/jpeg;base64,’);
background-size: cover; background-position: center;
position: relative; overflow: hidden;
}
.cta-band::before {
content: ‘’;
position: absolute; inset: 0;
background: rgba(17,17,17,0.88);
}
.cta-left, .cta-right { position: relative; z-index: 1; }
.cta-band .section-tag { margin-bottom: 0.5rem; }
.cta-title {
font-family: ‘Oswald’, sans-serif;
font-size: 2.4rem; font-weight: 700; text-transform: uppercase;
letter-spacing: 0.02em; color: var(–off-white); line-height: 1.1;
margin-bottom: 0.75rem;
}
.cta-title em { color: var(–pipe); font-style: normal; }
.cta-sub { font-size: 0.95rem; color: rgba(240,236,228,0.6); line-height: 1.7; }
.cta-right { text-align: right; }
.cta-phone {
font-family: ‘Oswald’, sans-serif;
font-size: 2.5rem; font-weight: 700; color: var(–pipe);
text-decoration: none; display: block; letter-spacing: 0.04em;
transition: color 0.2s;
}
.cta-phone:hover { color: var(–pipe-light); }
.cta-phone-label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
color: var(–muted); margin-bottom: 1.2rem; display: block;
}

/* ── CONTACT FORM ── */
.contact-section {
padding: 0 4rem 6rem;
display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
}
.contact-left .section-tag { margin-bottom: 0.5rem; }
.contact-left .section-title { margin-bottom: 1.5rem; font-size: 2.4rem; }
.contact-left p { font-size: 0.95rem; color: rgba(240,236,228,0.6); line-height: 1.8; margin-bottom: 2rem; }
.contact-info { display: flex; flex-direction: column; gap: 1rem; }
.contact-item {
display: flex; gap: 1rem; align-items: flex-start;
padding: 1rem; border: 1px solid var(–border);
}
.ci-icon { color: var(–pipe); font-size: 1.1rem; margin-top: 0.1rem; }
.ci-label {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
color: var(–muted); margin-bottom: 0.2rem;
}
.ci-val { font-size: 0.9rem; color: var(–off-white); }
.ci-val a { color: var(–off-white); text-decoration: none; transition: color 0.2s; }
.ci-val a:hover { color: var(–pipe); }

.quote-form { display: flex; flex-direction: column; gap: 1rem; }
.frow { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.fgroup input, .fgroup select, .fgroup textarea {
width: 100%; background: rgba(255,255,255,0.04);
border: 1px solid var(–border); padding: 0.9rem 1rem;
color: var(–off-white); font-family: ‘Source Serif 4’, serif;
font-size: 0.9rem; outline: none; transition: border-color 0.25s;
}
.fgroup input:focus, .fgroup select:focus, .fgroup textarea:focus {
border-color: var(–pipe);
}
.fgroup select option { background: #1a1a1a; }
.fgroup textarea { height: 90px; resize: none; }
.fsub {
font-family: ‘Oswald’, sans-serif; font-size: 1rem; font-weight: 600;
letter-spacing: 0.12em; text-transform: uppercase;
background: var(–pipe); color: #fff; border: 2px solid var(–pipe);
padding: 1rem; cursor: pointer; transition: all 0.25s; width: 100%;
}
.fsub:hover { background: transparent; color: var(–pipe); }
.f-note { font-size: 0.72rem; color: var(–muted); text-align: center; }

/* ── FOOTER ── */
footer {
background: #0c0c0c;
border-top: 1px solid rgba(224,107,26,0.15);
padding: 3.5rem 4rem 2rem;
}
.foot-grid {
display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
gap: 3rem; margin-bottom: 3rem;
}
.foot-brand .logo { font-size: 1.2rem; display: block; margin-bottom: 1rem; text-decoration: none; }
.foot-brand p { font-size: 0.85rem; color: var(–muted); line-height: 1.8; }
.foot-col h5 {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase;
color: var(–pipe); margin-bottom: 1.2rem;
}
.foot-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
.foot-col ul li a { font-size: 0.85rem; color: var(–muted); text-decoration: none; transition: color 0.2s; }
.foot-col ul li a:hover { color: var(–off-white); }
.foot-bottom {
border-top: 1px solid var(–border); padding-top: 1.5rem;
display: flex; justify-content: space-between;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 0.65rem; letter-spacing: 0.08em;
color: var(–muted); text-transform: uppercase;
}
.foot-bottom a { color: var(–pipe); text-decoration: none; }

/* ── ANIMATIONS ── */
@keyframes slideDown {
from { opacity: 0; transform: translateY(-16px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeUp {
from { opacity: 0; transform: translateY(28px); }
to { opacity: 1; transform: translateY(0); }
}
@keyframes slowZoom {
from { transform: scale(1.08); }
to { transform: scale(1); }
}
@keyframes ticker {
from { transform: translateX(0); }
to { transform: translateX(-50%); }
}

.reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s ease, transform 0.7s ease; }
.reveal.in { opacity: 1; transform: translateY(0); }

/* MOBILE */
@media (max-width: 860px) {
nav { padding: 1rem 1.5rem; }
.nav-right a:not(.nav-call) { display: none; }
.hero-content { padding: 0 1.5rem 4rem; }
.hero-stats { right: 1.5rem; bottom: 4rem; flex-direction: row; gap: 2rem; }
.gallery-grid { grid-template-rows: 200px 200px; }
.g3 { grid-row: 1; }
.section-header { padding: 0 1.5rem 2.5rem; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
.video-section, .why-section, .contact-section { grid-template-columns: 1fr; padding: 4rem 1.5rem; gap: 3rem; }
.services-section { padding: 4rem 1.5rem; }
.services-grid { grid-template-columns: 1fr; }
.svc { border-right: none; }
.cta-band { grid-template-columns: 1fr; margin: 0 1.5rem 4rem; padding: 2.5rem; }
.cta-right { text-align: left; }
.reviews-section { padding: 4rem 1.5rem; }
.foot-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
.foot-bottom { flex-direction: column; gap: 0.5rem; }
.frow { grid-template-columns: 1fr; }
}
</style>

</head>
